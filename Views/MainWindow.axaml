<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:AutoSkippy.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="AutoSkippy.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="AutoSkippy">

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>
	<Grid RowDefinitions="Auto,*,Auto" Margin="3">
		<Label Content="Control your measurement equipment sequentially with SCPI"
			   HorizontalAlignment="Center"
			   FontWeight="DemiBold"/>
		<Grid>
			
		</Grid>
		<Border Grid.Row="3" 
				BorderThickness="1" BorderBrush="{StaticResource SystemControlBackgroundBaseHighBrush}" Background="{StaticResource SystemControlBackgroundBaseLowBrush}" 
				HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
				Margin="1">
			<Panel>
				<TextBlock HorizontalAlignment="Left" FontWeight="Light" Text="© 2026 MiKoSoft for Total ESD Solutions" Margin="3"/>
				<TextBlock HorizontalAlignment="Right" FontWeight="Light" Text="{Binding VersionNumber, StringFormat=Version: {0}}" Margin="3"/>
			</Panel>
		</Border>
	</Grid>
</Window>
